# -----------------------------------------------------------------------
# Auto Insurance Demo — environment template
#
# This single file is the source of truth for all environment variables.
# Copy it to TWO locations and fill in your values in both copies:
#
#   copy .env.template .env          (read by the Node middleware)
#   copy .env.template ui\.env       (read by the Vite frontend build)
#
# Both .env files are excluded from git. This template is committed.
# Never put real credentials in this template file.
# -----------------------------------------------------------------------

# --- MarkLogic connection (used by the Node middleware) -----------------
ML_HOST=localhost
ML_PORT=8004
ML_USER=your-marklogic-username
ML_PASS=your-marklogic-password

# --- Middle-tier / UI wiring --------------------------------------------
# Port the Node middleware listens on
ML_MIDDLE_TIER_PORT=4004

# Allow the Vite dev server origin (CORS)
UI_ORIGIN=http://localhost:5173

# Name of the custom MarkLogic REST resource
VITE_ML_OPTIONS=corticonml-options

# Host and port the UI contacts (points at the Node middleware, not MarkLogic directly)
VITE_ML_HOST=localhost
VITE_ML_PORT=4004

# --- OpenAI (required only for the /api/chat chatbot endpoint) ----------
OPENAI_API_KEY=your-openai-api-key
# Optional: override the default model (gpt-4o-mini)
#OPENAI_MODEL=gpt-4o-mini
