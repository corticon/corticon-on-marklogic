<?xml version="1.0" encoding="UTF-8"?>
<options xmlns="http://marklogic.com/appservices/search">
  <extract-document-data selected="include">
    <extract-path>/payload</extract-path>
  </extract-document-data>

  <additional-query xmlns:cts="http://marklogic.com/cts">
    <cts:or-query>
      <cts:collection-query>
        <cts:uri>http://example.com/data/policy</cts:uri>
      </cts:collection-query>
      <cts:collection-query>
        <cts:uri>auto-insurance_output</cts:uri>
      </cts:collection-query>
    </cts:or-query>
  </additional-query>

  <constraint name="state">
    <range type="xs:string" facet="true" collation="http://marklogic.com/collation/codepoint">
      <path-index>/payload/state</path-index>
      <facet-option>frequency-order</facet-option>
      <facet-option>descending</facet-option>
    </range>
  </constraint>

  <constraint name="paymentPlan">
    <range type="xs:string" facet="true" collation="http://marklogic.com/collation/codepoint">
      <path-index>/payload/paymentPlan</path-index>
      <facet-option>frequency-order</facet-option>
      <facet-option>descending</facet-option>
    </range>
  </constraint>

  <constraint name="incidentType">
    <range type="xs:string" facet="true" collation="http://marklogic.com/collation/codepoint">
      <path-index>/payload/drivers/incidents/incidentType</path-index>
      <facet-option>frequency-order</facet-option>
      <facet-option>descending</facet-option>
    </range>
  </constraint>

  <constraint name="bodyStyle">
    <range type="xs:string" facet="true" collation="http://marklogic.com/collation/codepoint">
      <path-index>/payload/vehicles/bodyStyle</path-index>
      <facet-option>frequency-order</facet-option>
      <facet-option>descending</facet-option>
    </range>
  </constraint>

  <return-facets>true</return-facets>
  <transform-results apply="empty-snippet"/>
</options>