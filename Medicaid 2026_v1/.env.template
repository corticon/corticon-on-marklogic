# Copy to .env and edit before running scripts/init-from-env.ps1

# MarkLogic instance
APP_NAME=corticonml
MARKLOGIC_HOST=localhost
MARKLOGIC_REST_PORT=8003

# MarkLogic admin account (deployment)
MARKLOGIC_ADMIN_USERNAME=admin
MARKLOGIC_ADMIN_PASSWORD=change-me

# App users provisioned by ml-gradle security resources
MARKLOGIC_APP_ADMIN_USERNAME=corticonml-admin
MARKLOGIC_APP_ADMIN_PASSWORD=change-me
MARKLOGIC_APP_WRITER_USERNAME=corticonml-writer
MARKLOGIC_APP_WRITER_PASSWORD=change-me
MARKLOGIC_APP_READER_USERNAME=corticonml-reader
MARKLOGIC_APP_READER_PASSWORD=change-me

# REST auth mode for the app server
ML_REST_AUTHENTICATION=digestbasic

# Data collection prefix used by trigger/resource services
COLLECTION_PREFIX=Medicaid 2026_v1

# FastTrack archive filename placed under ui-fasttrack/
FASTTRACK_ARCHIVE=ml-fasttrack-2.0.0-20250701b.tgz
