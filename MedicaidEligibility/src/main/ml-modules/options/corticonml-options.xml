<?xml version="1.0" encoding="UTF-8"?>
<options xmlns="http://marklogic.com/appservices/search">

  <!-- Constraints -->
  <constraint name="searchable-text">
    <word>
      <json-property>householdId</json-property>
      <json-property>familyName</json-property>
      <json-property>first</json-property>
      <json-property>last</json-property>
      <json-property>ssn</json-property>
      <json-property>stateOfResidence</json-property>
      <json-property>text</json-property>
    </word>
  </constraint>

  <constraint name="program">
    <range type="xs:string" facet="true" collation="http://marklogic.com/collation/">
      <path-index>/payload/individual/classOfAssistance/name</path-index>
      <facet-option>limit=25</facet-option>
      <facet-option>frequency-order</facet-option>
    </range>
  </constraint>

  <constraint name="popgroup">
    <range type="xs:string" facet="true" collation="http://marklogic.com/collation/">
      <path-index>/payload/individual/classOfAssistance/group</path-index>
      <facet-option>limit=25</facet-option>
      <facet-option>frequency-order</facet-option>
    </range>
  </constraint>

  <constraint name="age">
    <range type="xs:int" facet="true">
      <path-index>/payload/individual/age</path-index>
      <bucket name="Child (0-18)" lt="19">0-18</bucket>
      <bucket name="Adult (19-64)" ge="19" lt="65">19-64</bucket>
      <bucket name="Senior (65+)" ge="65">65+</bucket>
    </range>
  </constraint>

  <constraint name="abd_population">
    <range type="xs:string" facet="true">
      <path-index>/payload/individual/isABDPopulation</path-index>
    </range>
  </constraint>

  <constraint name="disabled_or_blind">
    <range type="xs:string" facet="true">
      <path-index>/payload/individual/isDisabledOrBlind</path-index>
    </range>
  </constraint>

  <constraint name="pregnant">
    <range type="xs:string" facet="true">
      <path-index>/payload/individual/isPregnant</path-index>
    </range>
  </constraint>

  <constraint name="familySize">
    <range type="xs:int" facet="true">
      <path-index>/payload/familySize</path-index>
      <facet-option>limit=10</facet-option>
      <facet-option>frequency-order</facet-option>
    </range>
  </constraint>

  <constraint name="state">
    <range type="xs:string" facet="true" collation="http://marklogic.com/collation/">
      <path-index>/payload/stateOfResidence</path-index>
      <facet-option>limit=10</facet-option>
      <facet-option>frequency-order</facet-option>
    </range>
  </constraint>

  <!-- General search behavior -->
  <search-option>unfiltered</search-option>
  <quality-weight>0</quality-weight>

  <!-- Limit string search to the payload subtree for performance and relevance -->
  <searchable-expression>/payload</searchable-expression>

  <extract-metadata>
    <qname elem-name="householdId" elem-ns=""/>
    <qname elem-name="familySize" elem-ns=""/>
    <qname elem-name="annualIncome" elem-ns=""/>
    <qname elem-name="householdPercentFPL" elem-ns=""/>
    <qname elem-name="timestamp" elem-ns=""/>
  </extract-metadata>

  <!-- 🟩 CHANGE #1: Use apply="raw" so full JSON docs are returned, not just snippets -->
  <transform-results apply="raw"/>

  <!-- 🟩 CHANGE #2: Ensure payload and corticon nodes are included in results -->
  <extract-document-data selected="include">
    <extract-path>/payload</extract-path>
    <extract-path>/corticon</extract-path>
    <extract-path>/payload/corticon</extract-path>
  </extract-document-data>

  <!-- Sorting options -->
  <operator name="sort">
    <state name="householdId">
      <sort-order type="xs:string" direction="ascending">
        <path-index>/payload/householdId</path-index>
      </sort-order>
    </state>
    <state name="fpl">
      <sort-order type="xs:decimal" direction="descending">
        <path-index>/payload/householdPercentFPL</path-index>
      </sort-order>
    </state>
  </operator>

  <!-- Grammar (default query behavior) -->
  <grammar>
    <implicit>
      <cts:and-query strength="20" xmlns:cts="http://marklogic.com/cts"/>
    </implicit>
  </grammar>

</options>
