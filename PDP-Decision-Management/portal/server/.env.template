# MarkLogic REST connection used by the proxy
ML_HOST=localhost
ML_PORT=8004
ML_USER=your-marklogic-username
ML_PASS=your-marklogic-password
ML_MODULES_DATABASE=corticonml-modules

# Port for this middle tier
ML_MIDDLE_TIER_PORT=4005

# Allow the UI origin during development
UI_ORIGIN=http://localhost:5174

# Name of the custom MarkLogic resource used by the UI
VITE_ML_OPTIONS=corticonml-options

# Optional: enable chat explanations (leave blank to disable)
OPENAI_API_KEY=
# Optional: pick a model (defaults to gpt-4o-mini)
OPENAI_MODEL=gpt-4o-mini
