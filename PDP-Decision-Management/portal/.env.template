# ── Vite / Frontend Settings ────────────────────────────────────────────

# Vite dev server port (frontend)
VITE_ML_PORT=5174

# Vite proxy target — Express backend host and port
VITE_BACKEND_HOST=localhost
VITE_BACKEND_PORT=4005

# Frontend MarkLogic connection (proxied through Express backend)
VITE_ML_SCHEME=http
VITE_ML_HOST=localhost
VITE_ML_BASE_PATH=/api
VITE_ML_REST_PORT=8004

# MarkLogic credentials (used by frontend via Vite proxy)
VITE_ML_USERNAME=your-marklogic-username
VITE_ML_PASSWORD=your-marklogic-password

# Default Java home pre-filled when creating new deployment configs
VITE_DEFAULT_JAVA_HOME=C:\Program Files\Eclipse Adoptium\jdk-21.0.8.9-hotspot

# ── Backend ─────────────────────────────────────────────────────────────
# Backend vars (ML_HOST, ML_PORT, ML_USER, etc.) live in server/.env.template
# and are read by Express when it starts from that directory.
