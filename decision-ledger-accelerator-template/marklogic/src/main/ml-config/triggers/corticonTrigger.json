{
  "name": "corticonTrigger",
  "description": "Optional trigger-based Corticon execution",
  "event": {
    "data-event": {
      "collection-scope": {
        "uri": "http://example.com/data/input"
      },
      "document-content": {
        "update-kind": "create"
      },
      "when": "post-commit"
    }
  },
  "module": "ext/corticonTrigger.sjs",
  "module-db": "%%MODULES_DATABASE%%",
  "module-root": "/",
  "enabled": false,
  "recursive": false,
  "task-priority": "normal"
}

